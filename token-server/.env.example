# Agora Token Server Configuration
# Copy this file to .env and fill in your values

# Your Agora App ID (already configured in the app)
AGORA_APP_ID=89fdd88c9b594cf0947a48a8730e5f62

# Your Agora App Certificate (REQUIRED - get from https://console.agora.io/)
# Go to: Your Project → Edit → App Certificate
AGORA_APP_CERTIFICATE=YOUR_APP_CERTIFICATE_HERE

# Server Port (optional, defaults to 8080)
PORT=8080
