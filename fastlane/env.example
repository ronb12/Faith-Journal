# ================================
# FAITH JOURNAL FASTLANE ENVIRONMENT
# ================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Apple Developer Credentials
FASTLANE_USER=your-apple-developer-email@example.com
FASTLANE_PASSWORD=your-app-specific-password
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=your-app-specific-password

# App Store Connect API Key (preferred method)
# Create API Key at: https://appstoreconnect.apple.com/access/api
FASTLANE_API_KEY_PATH=./fastlane/AuthKey.p8
FASTLANE_API_KEY_ID=your_key_id
FASTLANE_API_KEY_ISSUER_ID=your_issuer_id

# Team IDs
FASTLANE_TEAM_ID=YOUR_TEAM_ID
FASTLANE_ITC_TEAM_ID=YOUR_ITC_TEAM_ID

# App Configuration
APP_IDENTIFIER=com.yourcompany.faithjournal
APP_NAME="Faith Journal"

# TestFlight Configuration
TESTFLIGHT_GROUPS="Beta Testers,Internal Team"
TESTFLIGHT_DISTRIBUTE_EXTERNAL=true
TESTFLIGHT_NOTIFY_EXTERNAL_TESTERS=true

# Slack Notifications (optional)
SLACK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#faith-journal

# Firebase (if needed for CI)
FIREBASE_TOKEN=your-firebase-token

# Git Configuration
GIT_BRANCH=main
GIT_URL=https://github.com/yourusername/faith-journal.git